rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regra principal para a configuração
    // ATENÇÃO: Como não temos sistema de login, as regras estão abertas para leitura e escrita.
    // Para produção, é recomendado implementar Firebase Auth e restringir a escrita.
    match /config/main {
      allow read, write: if true;
    }

    // Bloqueia acesso a qualquer outra coleção por segurança
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
